{
  "name": "overdue-scanner",
  "version": "1.0.0",
  "private": true,
  "description": "黑湖小工单 → 企业微信 逾期工单每日播报",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:dry": "tsx src/index.ts --dry-run",
    "dev:run": "tsx src/index.ts --run-now",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "dotenv": "^17.4.2",
    "js-sha3": "^0.9.3",
    "lowdb": "^7.0.1",
    "node-cron": "^3.0.3",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/node-cron": "^3.0.11",
    "nock": "^13.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
