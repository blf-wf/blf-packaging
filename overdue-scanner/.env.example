# 黑湖小工单
BLACKLAKE_PHONE=13800138000
BLACKLAKE_PASSWORD=your_password
BLACKLAKE_ORG_CODE=135851
BLACKLAKE_BASE_URL=https://liteweb.blacklake.cn

# 企业微信自建应用
WECOM_CORP_ID=your_corp_id
WECOM_AGENT_ID=your_agent_id
WECOM_SECRET=your_secret

# 管理群 chat_id（用于每日汇总播报 + 心跳监控）
WECOM_MGMT_CHAT_ID=your_chat_id

# 运行模式
# daemon: 定时调度（每日 08:00）
# run-now: 立即执行一次（发送真实消息）
# dry-run: 立即执行一次（仅输出日志，不发送消息）
RUN_MODE=daemon
